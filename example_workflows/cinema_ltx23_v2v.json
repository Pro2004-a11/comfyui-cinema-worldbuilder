{
  "_comment": "Cinema Worldbuilder example: VIDEO-TO-VIDEO refine (SDEdit) on LTX 2.3 22B distilled Q2_K GGUF. Adapted verbatim from the known-good ltx23_warp_v2v.json stack: keeps VHS_LoadVideo -> VAEEncode and the SplitSigmasDenoise (denoise 0.5) SDEdit path. ONLY change vs reference: the positive prompt text is wired from CinemaWorldbuilder_PromptComposer instead of being hardcoded; the negative prompt stays literal. PLACEHOLDER: edit VHS_LoadVideo 'video' to your source clip in ComfyUI/input/ (default 'warp_00_dolly_in_filled.mp4'). Edit the Cinema node inputs in the UI. Audio is decoded and muxed into VHS_VideoCombine. Requires the same LTX 2.3 models as cinema_ltx23_t2v.json.",

  "cinema_camera": {
    "class_type": "CinemaWorldbuilder_CameraBlock",
    "inputs": {
      "mode": "M1 - Narrative",
      "lens_mm": "55",
      "runtime_seconds": 4.0,
      "fps": "24",
      "palette": "warm amber and deep teal",
      "stage_lighting": "soft key with practical lamp glow"
    }
  },
  "cinema_audio": {
    "class_type": "CinemaWorldbuilder_AudioLine",
    "inputs": {
      "sounds": "distant city hum, footsteps on wet pavement, a soft breeze",
      "spoken_dialogue": false
    }
  },
  "cinema_prompt": {
    "class_type": "CinemaWorldbuilder_PromptComposer",
    "inputs": {
      "style_and_mood": "cinematic, moody, photoreal, shallow depth of field",
      "dynamic_description": "refine the source clip preserving its motion",
      "static_description": "the environment from the source video",
      "camera_block": ["cinema_camera", 0],
      "audio_line": ["cinema_audio", 0]
    }
  },

  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {"video": "warp_00_dolly_in_filled.mp4", "force_rate": 0, "custom_width": 0, "custom_height": 0, "frame_load_cap": 0, "skip_first_frames": 0, "select_every_nth": 1}
  },
  "2": {
    "class_type": "VAELoaderKJ",
    "inputs": {"vae_name": "ltx23_video_vae.safetensors", "device": "main_device", "weight_dtype": "bf16"}
  },
  "3": {
    "class_type": "VAELoaderKJ",
    "inputs": {"vae_name": "ltx23_audio_vae.safetensors", "device": "main_device", "weight_dtype": "bf16"}
  },
  "4": {
    "class_type": "VAEEncode",
    "inputs": {"pixels": ["1", 0], "vae": ["2", 0]}
  },
  "5": {
    "class_type": "LTXVEmptyLatentAudio",
    "inputs": {"frames_number": 49, "frame_rate": 24, "batch_size": 1, "audio_vae": ["3", 0]}
  },
  "6": {
    "class_type": "LTXVConcatAVLatent",
    "inputs": {"video_latent": ["4", 0], "audio_latent": ["5", 0]}
  },
  "7": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {"unet_name": "ltx-2.3-22b-distilled-1.1-Q2_K.gguf"}
  },
  "8": {
    "class_type": "LTXVChunkFeedForward",
    "inputs": {"model": ["7", 0], "chunks": 2, "dim_threshold": 4096}
  },
  "9": {
    "class_type": "DualCLIPLoaderGGUF",
    "inputs": {"clip_name1": "gemma-3-12b-it-IQ4_XS.gguf", "clip_name2": "ltx23_embeddings_connector.safetensors", "type": "ltxv"}
  },
  "10": {
    "class_type": "CLIPTextEncode",
    "inputs": {"clip": ["9", 0], "text": ["cinema_prompt", 0]}
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "inputs": {"clip": ["9", 0], "text": "blurry, distorted, jittery, warped, low quality"}
  },
  "12": {
    "class_type": "LTXVConditioning",
    "inputs": {"positive": ["10", 0], "negative": ["11", 0], "frame_rate": 24.0}
  },
  "13": {
    "class_type": "LTXVScheduler",
    "inputs": {"steps": 8, "max_shift": 2.05, "base_shift": 0.95, "stretch": true, "terminal": 0.1}
  },
  "14": {
    "class_type": "SplitSigmasDenoise",
    "inputs": {"sigmas": ["13", 0], "denoise": 0.5}
  },
  "15": {
    "class_type": "KSamplerSelect",
    "inputs": {"sampler_name": "euler_ancestral"}
  },
  "16": {
    "class_type": "SamplerCustom",
    "inputs": {"model": ["8", 0], "add_noise": true, "noise_seed": 0, "cfg": 1.0, "positive": ["12", 0], "negative": ["12", 1], "sampler": ["15", 0], "sigmas": ["14", 1], "latent_image": ["6", 0]}
  },
  "17": {
    "class_type": "LTXVSeparateAVLatent",
    "inputs": {"av_latent": ["16", 0]}
  },
  "18": {
    "class_type": "VAEDecodeTiled",
    "inputs": {"samples": ["17", 0], "vae": ["2", 0], "tile_size": 512, "overlap": 64, "temporal_size": 64, "temporal_overlap": 8}
  },
  "20": {
    "class_type": "LTXVAudioVAEDecode",
    "inputs": {"samples": ["17", 1], "audio_vae": ["3", 0]}
  },
  "19": {
    "class_type": "VHS_VideoCombine",
    "inputs": {"images": ["18", 0], "audio": ["20", 0], "frame_rate": 24, "loop_count": 0, "filename_prefix": "cinema_v2v", "format": "video/h264-mp4", "pingpong": false, "save_output": true}
  }
}

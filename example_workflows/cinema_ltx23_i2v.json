{
  "_comment": "Cinema Worldbuilder example: IMAGE-TO-VIDEO on LTX 2.3 22B distilled Q2_K GGUF. Rebuilt on the t2v-validated sampling chain (ManualSigmas + SamplerCustomAdvanced + RandomNoise + CFGGuider) — LTXVScheduler was leaving the schedule undenoised on this distilled model. LoadImage supplies the first frame via LTXVAddGuide (frame_idx 0, strength 1.0); CFGGuider's positive/negative pull from add_guide's rewritten conditioning (the i2v anchor) — NOT from the raw conditioning node. PLACEHOLDER: edit the LoadImage 'image' field to your uploaded first-frame image (default 'example.png' must exist in ComfyUI/input/). Edit the Cinema node inputs in the UI. Requires the same LTX 2.3 models as cinema_ltx23_t2v.json.",
  "cinema_camera": {
    "class_type": "CinemaWorldbuilder_CameraBlock",
    "inputs": {
      "mode": "M1 - Narrative",
      "lens_mm": "55",
      "runtime_seconds": 4.0,
      "fps": "24",
      "palette": "warm amber and deep teal",
      "stage_lighting": "soft key with practical lamp glow"
    }
  },
  "cinema_audio": {
    "class_type": "CinemaWorldbuilder_AudioLine",
    "inputs": {
      "sounds": "distant city hum, footsteps on wet pavement, a soft breeze",
      "spoken_dialogue": false
    }
  },
  "cinema_prompt": {
    "class_type": "CinemaWorldbuilder_PromptComposer",
    "inputs": {
      "style_and_mood": "cinematic, moody, photoreal, shallow depth of field",
      "dynamic_description": "the scene comes alive as the camera slowly pushes in",
      "static_description": "the environment established by the loaded first frame",
      "camera_block": [
        "cinema_camera",
        0
      ],
      "audio_line": [
        "cinema_audio",
        0
      ]
    }
  },
  "video_vae": {
    "class_type": "VAELoaderKJ",
    "inputs": {
      "vae_name": "ltx23_video_vae.safetensors",
      "device": "main_device",
      "weight_dtype": "bf16"
    }
  },
  "audio_vae": {
    "class_type": "VAELoaderKJ",
    "inputs": {
      "vae_name": "ltx23_audio_vae.safetensors",
      "device": "main_device",
      "weight_dtype": "bf16"
    }
  },
  "load_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "example.png"
    }
  },
  "empty_video_latent": {
    "class_type": "EmptyLTXVLatentVideo",
    "inputs": {
      "width": 768,
      "height": 512,
      "length": [
        "cinema_camera",
        1
      ],
      "batch_size": 1
    }
  },
  "empty_audio_latent": {
    "class_type": "LTXVEmptyLatentAudio",
    "inputs": {
      "frames_number": [
        "cinema_camera",
        1
      ],
      "frame_rate": 24,
      "batch_size": 1,
      "audio_vae": [
        "audio_vae",
        0
      ]
    }
  },
  "unet": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "ltx-2.3-22b-distilled-1.1-Q2_K.gguf"
    }
  },
  "model": {
    "class_type": "LTXVChunkFeedForward",
    "inputs": {
      "model": [
        "unet",
        0
      ],
      "chunks": 2,
      "dim_threshold": 4096
    }
  },
  "clip": {
    "class_type": "DualCLIPLoaderGGUF",
    "inputs": {
      "clip_name1": "gemma-3-12b-it-IQ4_XS.gguf",
      "clip_name2": "ltx23_embeddings_connector.safetensors",
      "type": "ltxv"
    }
  },
  "positive": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": [
        "clip",
        0
      ],
      "text": [
        "cinema_prompt",
        0
      ]
    }
  },
  "negative": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": [
        "clip",
        0
      ],
      "text": "blurry, distorted, jittery, warped, low quality"
    }
  },
  "conditioning": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive": [
        "positive",
        0
      ],
      "negative": [
        "negative",
        0
      ],
      "frame_rate": 24.0
    }
  },
  "add_guide": {
    "class_type": "LTXVAddGuide",
    "inputs": {
      "positive": [
        "conditioning",
        0
      ],
      "negative": [
        "conditioning",
        1
      ],
      "vae": [
        "video_vae",
        0
      ],
      "latent": [
        "empty_video_latent",
        0
      ],
      "image": [
        "load_image",
        0
      ],
      "frame_idx": 0,
      "strength": 1.0
    }
  },
  "concat_av": {
    "class_type": "LTXVConcatAVLatent",
    "inputs": {
      "video_latent": [
        "add_guide",
        2
      ],
      "audio_latent": [
        "empty_audio_latent",
        0
      ]
    }
  },
  "sigmas": {
    "class_type": "ManualSigmas",
    "inputs": {
      "sigmas": "1., 0.99375, 0.9875, 0.98125, 0.975, 0.909375, 0.725, 0.421875, 0.0"
    }
  },
  "sampler_select": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler_ancestral"
    }
  },
  "noise": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": 420
    }
  },
  "guider": {
    "class_type": "CFGGuider",
    "inputs": {
      "model": [
        "model",
        0
      ],
      "positive": [
        "add_guide",
        0
      ],
      "negative": [
        "add_guide",
        1
      ],
      "cfg": 1.0
    }
  },
  "sampler": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": [
        "noise",
        0
      ],
      "guider": [
        "guider",
        0
      ],
      "sampler": [
        "sampler_select",
        0
      ],
      "sigmas": [
        "sigmas",
        0
      ],
      "latent_image": [
        "concat_av",
        0
      ]
    }
  },
  "separate_av": {
    "class_type": "LTXVSeparateAVLatent",
    "inputs": {
      "av_latent": [
        "sampler",
        0
      ]
    }
  },
  "decode_video": {
    "class_type": "VAEDecodeTiled",
    "inputs": {
      "samples": [
        "separate_av",
        0
      ],
      "vae": [
        "video_vae",
        0
      ],
      "tile_size": 512,
      "overlap": 64,
      "temporal_size": 64,
      "temporal_overlap": 8
    }
  },
  "decode_audio": {
    "class_type": "LTXVAudioVAEDecode",
    "inputs": {
      "samples": [
        "separate_av",
        1
      ],
      "audio_vae": [
        "audio_vae",
        0
      ]
    }
  },
  "combine": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": [
        "decode_video",
        0
      ],
      "audio": [
        "decode_audio",
        0
      ],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "cinema_i2v",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
